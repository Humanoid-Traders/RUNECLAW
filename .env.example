# ============================================================
# RUNECLAW -- AI Trading Command Core
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings have safe defaults. Only TELEGRAM_BOT_TOKEN is
# required for Telegram mode.
# ============================================================

# -- Safety Switches ------------------------------------------
# Simulation mode ON by default. Live trading requires BOTH
# flags to be explicitly set.
SIMULATION_MODE=true
LIVE_TRADING_ENABLED=false

# -- Per-user live trading (BYOK) -----------------------------
# When ON, each user's confirmed live trade executes on THEIR OWN linked Bitget
# account (linked via /connect, encrypted at rest) instead of the shared
# operator account. Default OFF — until set, the bot uses only the operator
# account exactly as before. Regular users are manual-confirm only; admins keep
# auto-trade (see AUTO_CONFIRM_* below). See docs/LIVE_TRADING_ENABLEMENT.md.
PER_USER_LIVE_ENABLED=false
# Master key (urlsafe-base64 Fernet) used to encrypt per-user API keys at rest.
# If unset, a key is generated and persisted to data/.exchange_secret.key (0600)
# — set this explicitly in production so ciphertext survives a wiped data dir.
RUNECLAW_SECRETS_KEY=

# -- Paper Trading --------------------------------------------
# Starting balance for the paper trading portfolio (USD).
PAPER_BALANCE_USD=10000

# -- Bitget Exchange -------------------------------------------
# API credentials from https://www.bitget.com/account/newapi
# Sandbox mode is ON by default. Set to false for real market data.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_SANDBOX=true
# Asset universe: "all" scans all USDT pairs, "solana" prioritizes Solana ecosystem tokens
# ASSET_UNIVERSE=all

# -- Telegram Bot ----------------------------------------------
# Create a bot via @BotFather on Telegram to get a token.
# CHAT_ID: required. Comma-separated list of allowed chat IDs.
# If unset, the bot rejects all commands.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated admin Telegram IDs. Admins keep auto-trade (below); regular
# users are manual-confirm only.
ADMIN_TELEGRAM_IDS=

# -- Auto-confirmation (admins) -------------------------------
# Signals at/above this blended confidence auto-execute without a human button
# press. Default 1.0 = DISABLED (everyone manual-confirm). For the admin
# "85% or higher" auto-trade policy, set 0.85 AND enable live auto-confirm.
# Auto-confirmed trades run on the OPERATOR account (user_id="auto"); a regular
# user's trade is NEVER auto-confirmed.
AUTO_CONFIRM_THRESHOLD=1.0
AUTO_CONFIRM_LIVE_ENABLED=false

# -- Confidence calibration -----------------------------------
# When ON, the final blended confidence is remapped through a monotonic
# reliability curve fitted from the bot's OWN closed-trade history, so a
# confidence value reflects realized win rate (e.g. 0.85 -> ~85% historical
# win rate). Default OFF — until enabled it runs shadow-mode (the would-be
# value is logged, nothing is applied). Refit the curve from history with the
# admin command /calibration refit. See docs/CONFIDENCE_CALIBRATION.md.
CONFIDENCE_CALIBRATION_ENABLED=false

# -- Per-setup expectancy -------------------------------------
# When ON, a setup's own historical win rate (symbol + regime + direction, from
# completed trades) applies a small bounded nudge (max +-0.05) to confidence.
# Default OFF — until enabled it runs shadow-mode (the would-be nudge is logged,
# nothing is applied). Reload from history with /calibration refit.
SETUP_EXPECTANCY_ENABLED=false

# -- Voter-weight learning (application) ----------------------
# When ON, each confluence voter's hand-tuned weight is multiplied by a learned,
# bounded ([0.5, 1.5]) multiplier reflecting how well that voter has predicted
# winning trades. Default OFF — until enabled, weights are byte-identical to the
# hand-tuned defaults. Refit from history with /calibration refit.
VOTER_WEIGHT_LEARNING_ENABLED=false

# -- External sentiment (Fear & Greed) ------------------------
# When ON, the sentiment voter blends the live market-wide Fear & Greed index
# (alternative.me, free, no key) as a bounded (+-0.3) contrarian signal —
# extreme fear = contrarian-bullish, extreme greed = contrarian-bearish. Cached
# with a TTL; fail-open. Default OFF — until enabled the voter is purely
# price-derived (no external network call).
EXTERNAL_SENTIMENT_ENABLED=false

# -- Funding carry-cost awareness -----------------------------
# When ON, applies a small bounded confidence haircut (max -0.05) when a trade
# would PAY adverse funding over its expected hold — the carry-cost dimension the
# instantaneous funding signals miss (a swing pays many 8h funding intervals, a
# scalp ~none). Only ever REDUCES confidence; never bypasses risk. Default OFF.
FUNDING_COST_AWARE_ENABLED=false

# -- LLM Configuration ----------------------------------------
# BYOK (Bring Your Own Key) — supports 10 providers.
# Set LLM_PROVIDER to select. Leave LLM_API_KEY blank for rule-based fallback (FREE).
# Runtime switching available via Telegram: /setllm <provider> <key>
#
# PROVIDER OPTIONS:
#   openai      → GPT-4o, GPT-4-turbo, o1-mini  (best reasoning, paid)
#   anthropic   → Claude Sonnet/Opus             (great safety, paid, pip install anthropic)
#   gemini      → Gemini 2.5 Flash               (free tier, reasoning)  ← DEFAULT
#   groq        → Llama 3.3 70B, Mixtral          (fastest, free tier!)
#   mistral     → Mistral Large                   (cheap, fast, EU)
#   deepseek    → DeepSeek Chat                   (extremely cheap, $0.14/M tokens)
#   together    → 100+ open models                ($5 free credits)
#   ollama      → Local models (Llama3, Mistral)   (free, private, no key needed)
#   openrouter  → Routes to 100+ models            (free models available)
#   alibaba     → Qwen Max/Plus/Turbo             ($30 free credits!)
#   custom      → Any OpenAI-compatible endpoint
#
# Get free keys:
#   Groq:       https://console.groq.com/keys          (no credit card)
#   Gemini:     https://aistudio.google.com/apikey      (no credit card)
#   OpenRouter: https://openrouter.ai/keys              (free models)
#   Ollama:     https://ollama.com/download              (no key needed)
#   Alibaba:    https://dashscope.console.aliyun.com/apiKey  ($30 free credits)
#   OpenAI:     https://platform.openai.com/api-keys
#   Anthropic:  https://console.anthropic.com/
#   DeepSeek:   https://platform.deepseek.com/api_keys
#
# WARNING: Each /analyze call costs ~$0.01-0.03 at GPT-4o pricing.
#          Groq/Gemini/Ollama are FREE alternatives.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SEC=15
LLM_DAILY_LIMIT=500
LLM_DAILY_BUDGET_USD=5.0

# -- Multi-Tier LLM Routing (optional) ----------------------------
# Use DIFFERENT providers for different task types. Each tier falls back
# to LLM_PROVIDER if not set. Keys auto-resolve from provider-specific envs.
#
# TIERS:
#   SCAN     → high-frequency scans (needs speed)         → Gemini Flash (free)
#   THESIS   → trade thesis generation (needs reasoning)  → Claude Sonnet (best quality/cost)
#   LEARNING → reflection / macro learner (needs depth)   → Gemini Flash (free, 1M context)
#   CHAT     → user Q&A via Telegram (balanced)           → Gemini Flash (free, fast)
#
# COST GUIDE (per 1M tokens, input/output):
#   Claude Opus 4.8:   $15 / $75   — overkill for most tasks
#   Claude Sonnet 4.6: $3  / $15   — best reasoning/cost for thesis
#   Gemini 2.5 Flash:  free tier    — ideal for scan/chat/learning
#   Groq Llama 3.3:    free tier    — fastest inference, good fallback
#   DeepSeek Chat:     $0.14 / $0.28 — cheapest paid option
#
LLM_TIER_SCAN_PROVIDER=gemini
LLM_TIER_SCAN_MODEL=gemini-2.5-flash
LLM_TIER_THESIS_PROVIDER=anthropic
LLM_TIER_THESIS_MODEL=claude-sonnet-4-6
LLM_TIER_LEARNING_PROVIDER=gemini
LLM_TIER_LEARNING_MODEL=gemini-2.5-flash
LLM_TIER_CHAT_PROVIDER=gemini
LLM_TIER_CHAT_MODEL=gemini-2.5-flash

# -- Provider-Specific API Keys -----------------------------------
# Set these to enable multi-tier routing with different providers.
# Each provider key is auto-detected by tier routing.
# GEMINI_API_KEY=             # Free at https://aistudio.google.com/apikey
# GROQ_API_KEY=               # Free at https://console.groq.com/keys
# ANTHROPIC_API_KEY=          # https://console.anthropic.com/
# DEEPSEEK_API_KEY=           # https://platform.deepseek.com/api_keys
# OPENAI_API_KEY=             # https://platform.openai.com/api-keys
# ALIBABA_API_KEY=            # Qwen via Bitget Hackathon endpoint (hackathon.bitgetops.com/v1)

# -- On-chain data (BYOK, optional) -------------------------------
# Brings exchange-flow / whale / stablecoin metrics in as a bounded confluence
# vote. INERT without a key (like the LLM rule-based fallback): fail-open, cached,
# never blocks the decision path. Default OFF. Provider-agnostic — point
# ONCHAIN_BASE_URL at a Glassnode/Arkham/Nansen-style endpoint returning
# normalised metrics. See bot/core/onchain.py and docs/ONCHAIN.md.
ONCHAIN_ENABLED=false
ONCHAIN_API_KEY=
ONCHAIN_BASE_URL=
ONCHAIN_PROVIDER=

# -- Commission --------------------------------------------------
# Commission percentage per trade (entry and exit each).
COMMISSION_PCT=0.1

# -- Risk Limits -----------------------------------------------
# The values below mirror the in-code defaults (bot/config.py RiskLimits), so
# copying this file reproduces the bot's actual behavior. Lower them for a more
# conservative posture. NOTE: MAX_POSITION_PCT/MAX_SYMBOL_EXPOSURE_PCT bound
# MARGIN (collateral) as a % of equity — at DEFAULT_LEVERAGE the resulting
# notional exposure is that % × leverage (see bot/risk/risk_engine.py header).
MAX_POSITION_PCT=13.0
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=5
# MAX_CORRELATION: reserved for future pairwise correlation matrix check.
# Currently unused -- concentration is enforced by MAX_CORRELATION_PER_GROUP.
# MAX_CORRELATION=0.85
MIN_RISK_REWARD=1.2
MIN_CONFIDENCE=0.55
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_AFTER_LOSS_SEC=120
MAX_PORTFOLIO_EXPOSURE_PCT=80.0
MAX_SYMBOL_EXPOSURE_PCT=20.0
MAX_CORRELATION_PER_GROUP=2
VOLATILITY_GUARD_ATR_PCT=7.0
STALE_DATA_MAX_AGE_SEC=300
REQUIRE_STOP_LOSS=true

# -- Scanner Settings ------------------------------------------
# How often the engine scans for new signals (seconds).
SCAN_INTERVAL=60

# -- Website Auth & Sync ----------------------------------------
# REQUIRED for production. Auto-generated if unset (ephemeral only).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
BOT_SYNC_SECRET=

# -- Dashboard API (F-02 FIX) ------------------------------------
# Bearer token required for /api/* endpoints. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=
# Allowed CORS origin (F-03 FIX). Leave empty for same-origin only.
# DASHBOARD_CORS_ORIGIN=https://yourdomain.com

# -- Redis (F-04 FIX) -------------------------------------------
# Password for Redis. Must match docker-compose.yml.
REDIS_PASSWORD=

# -- MCP Server --------------------------------------------------
# Bearer token for MCP tool calls. Generate same as DASHBOARD_TOKEN.
MCP_AUTH_TOKEN=
