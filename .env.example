# ============================================================
# RUNECLAW -- AI Trading Command Core
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings have safe defaults. Only TELEGRAM_BOT_TOKEN is
# required for Telegram mode.
# ============================================================

# -- Safety Switches ------------------------------------------
# Simulation mode ON by default. Live trading requires BOTH
# flags to be explicitly set.
SIMULATION_MODE=true
LIVE_TRADING_ENABLED=false

# -- Paper Trading --------------------------------------------
# Starting balance for the paper trading portfolio (USD).
PAPER_BALANCE_USD=10000

# -- Bitget Exchange -------------------------------------------
# API credentials from https://www.bitget.com/account/newapi
# Sandbox mode is ON by default. Set to false for real market data.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_SANDBOX=true
# Asset universe: "all" scans all USDT pairs, "solana" prioritizes Solana ecosystem tokens
# ASSET_UNIVERSE=all

# -- Telegram Bot ----------------------------------------------
# Create a bot via @BotFather on Telegram to get a token.
# CHAT_ID: required. Comma-separated list of allowed chat IDs.
# If unset, the bot rejects all commands unless TELEGRAM_ALLOW_OPEN=true.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ALLOW_OPEN=true  # Uncomment ONLY for local dev to allow any chat

# -- LLM Configuration ----------------------------------------
# OpenAI-compatible API key for AI-powered trade analysis.
# Supports any OpenAI-compatible provider:
#   - OpenAI (default):   leave LLM_BASE_URL unset
#   - Alibaba Qwen:       LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#                          LLM_MODEL=qwen-max  (or qwen-plus, qwen-turbo)
#   - OpenRouter:          LLM_BASE_URL=https://openrouter.ai/api/v1
#                          LLM_MODEL=qwen/qwen3.6-35b-a3b
#   - Together AI:         LLM_BASE_URL=https://api.together.xyz/v1
#   - Local (vLLM/Ollama): LLM_BASE_URL=http://localhost:8000/v1
# If LLM_API_KEY is blank, the analyzer falls back to rule-based strategy (FREE).
# WARNING: Each /analyze call costs ~$0.01-0.03 at GPT-4o pricing.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SEC=30
LLM_DAILY_LIMIT=100
LLM_DAILY_BUDGET_USD=5.0

# -- Commission --------------------------------------------------
# Commission percentage per trade (entry and exit each).
COMMISSION_PCT=0.1

# -- Risk Limits -----------------------------------------------
# These can be tuned per strategy. Defaults are conservative.
MAX_POSITION_PCT=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=5
# MAX_CORRELATION: reserved for future pairwise correlation matrix check.
# Currently unused -- concentration is enforced by MAX_CORRELATION_PER_GROUP.
# MAX_CORRELATION=0.85
MIN_RISK_REWARD=1.2
MIN_CONFIDENCE=0.60
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_AFTER_LOSS_SEC=300
MAX_PORTFOLIO_EXPOSURE_PCT=80.0
MAX_SYMBOL_EXPOSURE_PCT=20.0
MAX_CORRELATION_PER_GROUP=2
VOLATILITY_GUARD_ATR_PCT=6.0
STALE_DATA_MAX_AGE_SEC=300
REQUIRE_STOP_LOSS=true

# -- Scanner Settings ------------------------------------------
# How often the engine scans for new signals (seconds).
SCAN_INTERVAL=60
