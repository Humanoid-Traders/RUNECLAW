# ============================================================
# RUNECLAW -- AI Trading Command Core
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings have safe defaults. Only TELEGRAM_BOT_TOKEN is
# required for Telegram mode.
# ============================================================

# -- Safety Switches ------------------------------------------
# Simulation mode ON by default. Live trading requires BOTH
# flags to be explicitly set.
SIMULATION_MODE=true
LIVE_TRADING_ENABLED=false

# -- Per-user live trading (BYOK) -----------------------------
# When ON, each user's confirmed live trade executes on THEIR OWN linked Bitget
# account (linked via /connect, encrypted at rest) instead of the shared
# operator account. Default OFF — until set, the bot uses only the operator
# account exactly as before. Regular users are manual-confirm only; admins keep
# auto-trade (see AUTO_CONFIRM_* below). See docs/LIVE_TRADING_ENABLEMENT.md.
PER_USER_LIVE_ENABLED=false
# Master key (urlsafe-base64 Fernet) used to encrypt per-user API keys AND the
# operator secrets vault at rest. If unset, a key is generated and persisted to
# data/.exchange_secret.key (0600). If you DO set it here, it is also mirrored to
# that file, so a wiped .env falls back to the same key and never orphans the
# ciphertext — set it explicitly in production.
RUNECLAW_SECRETS_KEY=

# -- Secrets vault (survive a wiped .env) ---------------------
# On boot the bot mirrors the operator's money/auth-critical secrets (BITGET_*,
# TELEGRAM_BOT_TOKEN, LLM/venue keys) into an ENCRYPTED file under data/, and
# restores any that .env has lost — so a redeploy that wipes .env comes back
# fully authenticated instead of failing to place stops (Bitget 40012). This
# ONLY works if data/ persists across redeploys — run ./deploy.sh (or mount a
# volume) so both .env and data/ live outside the repo. Extend the managed set
# with RUNECLAW_VAULT_KEYS=KEY1,KEY2. Default ON.
SECRETS_VAULT_ENABLED=true
# RUNECLAW_VAULT_KEYS=

# -- Paper Trading --------------------------------------------
# Starting balance for the paper trading portfolio (USD).
PAPER_BALANCE_USD=10000

# -- Live trading venue ----------------------------------------
# "bitget" (default, USDT-M perps), "hyperliquid" (USDC perps DEX),
# "bybit" (USDT linear perps), or "bingx" (USDT perps, $2 min order).
# Applies to the operator's shared executor; per-user (/connect)
# executors are always Bitget. Market-data scanning stays on Bitget
# either way — the venue only changes where orders are placed.
# Runtime switching: /venue <name> in Telegram (persists, no restart).
# VENUE=bitget

# -- Bitget Exchange -------------------------------------------
# API credentials from https://www.bitget.com/account/newapi
# Sandbox mode is ON by default. Set to false for real market data.
BITGET_API_KEY=
BITGET_API_SECRET=
# The API passphrase you set when CREATING the key. Canonical name is
# BITGET_PASSPHRASE; the legacy BITGET_API_PASSPHRASE spelling is also accepted.
# A blank/mismatched passphrase makes Bitget reject EVERY request ("requires
# password") — the engine then can't authenticate or protect open positions.
BITGET_PASSPHRASE=
# Bitget demo trading (PAPTRADING). false = production (default). Setting
# true requires API keys created inside Bitget DEMO trading — live keys will
# fail validation with "exchange environment is incorrect" (40099).
BITGET_SANDBOX=false

# -- Hyperliquid (only when VENUE=hyperliquid) -----------------
# Use a dedicated API/agent wallet from https://app.hyperliquid.xyz/API —
# NOT your main wallet's private key. Min order notional is $10.
# HYPERLIQUID_WALLET_ADDRESS=
# HYPERLIQUID_PRIVATE_KEY=
# HYPERLIQUID_TESTNET=false

# -- Bybit (only when VENUE=bybit or switched via /venue) ------
# USDT linear perps, ~$5 min order. Account must be in ONE-WAY
# position mode (Bybit's default).
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# -- BingX (only when VENUE=bingx or switched via /venue) ------
# USDT perps with a $2 min order — smallest-account friendly.
# Account must be in ONE-WAY position mode.
# BINGX_API_KEY=
# BINGX_API_SECRET=
# Asset universe: "all" scans all USDT pairs, "solana" prioritizes Solana ecosystem tokens
# ASSET_UNIVERSE=all

# -- Live position caps (MARGIN) ------------------------------
# Hard caps enforced by the live executor's preflight. Defaults are the
# conservative micro-test values — RAISE these for real-size live trading.
# These are MARGIN figures; exchange notional = margin x leverage. Read at
# launch, so set before starting the bot.
# MICRO_MAX_POSITION_USD=100      # max margin per trade
# MICRO_MAX_TOTAL_EXPOSURE=500    # max total margin across open positions
# MICRO_MAX_OPEN_POSITIONS=5      # max concurrent positions

# -- Telegram Bot ----------------------------------------------
# Create a bot via @BotFather on Telegram to get a token.
# CHAT_ID: required. Comma-separated list of allowed chat IDs.
# If unset, the bot rejects all commands.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated admin Telegram IDs. Admins keep auto-trade (below), get every
# admin command (/halt, /closeall, /grant_live, ...), and trade on the OPERATOR
# account. Do NOT list regular users here — use LIVE_TRADER_TELEGRAM_IDS instead.
ADMIN_TELEGRAM_IDS=
# Comma-separated Telegram IDs of regular users allowed to trade LIVE on their
# OWN linked Bitget account (under PER_USER_LIVE_ENABLED). They are permitted on
# the bot + live-trade allowlist but are NOT operators/admins: per-user risk
# isolation, own-account execution, and own-equity sizing all apply, and they get
# no admin commands. This is the correct knob for onboarding live users — listing
# them in ADMIN_TELEGRAM_IDS would make them admins AND route them to the operator
# account (defeating per-user isolation). Still requires /approve + /grant_live.
LIVE_TRADER_TELEGRAM_IDS=

# -- Auto-confirmation (admins) -------------------------------
# Signals at/above this blended confidence auto-execute without a human button
# press. Default 1.0 = DISABLED (everyone manual-confirm). For the admin
# "85% or higher" auto-trade policy, set 0.85 AND enable live auto-confirm.
# Auto-confirmed trades run on the OPERATOR account (user_id="auto"); a regular
# user's trade is NEVER auto-confirmed.
AUTO_CONFIRM_THRESHOLD=1.0
AUTO_CONFIRM_LIVE_ENABLED=false
# Gate auto-confirm on CALIBRATED confidence (default OFF). When ON and a fitted
# calibrator exists, the threshold is tested against min(raw, calibrated) — so a
# real-money auto-trade needs both the raw blend AND the measured win-rate to
# clear the bar (makes 0.85 mean ~85% realized, not a raw blend). Strictly
# tightens; no-op until the calibrator has data (refit via /calibration refit).
# AUTO_CONFIRM_USE_CALIBRATED=false

# -- Per-user BYOK LLM routing --------------------------------
# When ON, the LLM thesis for a command a user runs by hand (/analyze) uses THAT
# user's own provider key (from their encrypted /setllm settings) instead of the
# operator's — their analysis draws on their own quota/billing. Fail-open: no key
# / invalid provider / un-buildable client falls back to the operator config. The
# continuous background scan is unaffected. Default OFF.
# PER_USER_LLM_ENABLED=false
# Tier-based operator LLM routing: when ON, a user's tier (admin/elite/pro from
# the user store) maps to operator-funded LLM quality for their /analyze — elite
# → Sonnet thesis, pro → Gemini thesis, admin → Sonnet everywhere. basic/free keep
# the default routing (never downgraded). A user's own key (above) takes
# precedence. Fail-open to default routing. Default OFF.
# PER_USER_LLM_TIERS_ENABLED=false

# -- Confidence calibration -----------------------------------
# When ON, the final blended confidence is remapped through a monotonic
# reliability curve fitted from the bot's OWN closed-trade history, so a
# confidence value reflects realized win rate (e.g. 0.85 -> ~85% historical
# win rate). Default OFF — until enabled it runs shadow-mode (the would-be
# value is logged, nothing is applied). Refit the curve from history with the
# admin command /calibration refit. See docs/CONFIDENCE_CALIBRATION.md.
CONFIDENCE_CALIBRATION_ENABLED=false

# -- Confidence blend weights ---------------------------------
# blended = llm_confidence*LLM_BLEND_WEIGHT + confluence*CONFLUENCE_BLEND_WEIGHT.
# Defaults (0.6 / 0.4) preserve prior behaviour. Lower LLM_BLEND_WEIGHT to lean
# on the deterministic confluence once calibration data shows the rule engine
# matches the LLM (LLM Optimization Plan Phase 5).
# LLM_BLEND_WEIGHT=0.6
# CONFLUENCE_BLEND_WEIGHT=0.4
# Uncalibrated-LLM weight cap: when ON *and* CONFIDENCE_CALIBRATION_ENABLED is
# OFF, the LLM weight is capped at UNCALIBRATED_LLM_WEIGHT_CAP and the freed
# weight shifts to confluence — so an unproven LLM can't dominate sizing. The cap
# lifts automatically once calibration is on. Default OFF (no behaviour change).
# UNCALIBRATED_LLM_WEIGHT_CAP_ENABLED=false
# UNCALIBRATED_LLM_WEIGHT_CAP=0.4

# -- Regime hard gates ----------------------------------------
# When ON, the lowest-edge regimes become hard NO-TRADES instead of just getting
# a confidence penalty: CHOP/UNKNOWN are skipped entirely, and a counter-trend
# entry into a STRONG trend (ADX >= REGIME_STRONG_ADX — SHORT in an uptrend or
# LONG in a downtrend) is skipped. Default OFF preserves the soft-penalty
# behaviour exactly.
# REGIME_HARD_GATES_ENABLED=false
# REGIME_STRONG_ADX=30

# -- Per-setup expectancy -------------------------------------
# When ON, a setup's own historical win rate (symbol + regime + direction, from
# completed trades) applies a small bounded nudge (max +-0.05) to confidence.
# Default OFF — until enabled it runs shadow-mode (the would-be nudge is logged,
# nothing is applied). Reload from history with /calibration refit.
SETUP_EXPECTANCY_ENABLED=false

# -- Voter-weight learning (application) ----------------------
# When ON, each confluence voter's hand-tuned weight is multiplied by a learned,
# bounded ([0.5, 1.5]) multiplier reflecting how well that voter has predicted
# winning trades. Default OFF — until enabled, weights are byte-identical to the
# hand-tuned defaults. Refit from history with /calibration refit.
VOTER_WEIGHT_LEARNING_ENABLED=false

# -- External sentiment (Fear & Greed) ------------------------
# When ON, the sentiment voter blends the live market-wide Fear & Greed index
# (alternative.me, free, no key) as a bounded (+-0.3) contrarian signal —
# extreme fear = contrarian-bullish, extreme greed = contrarian-bearish. Cached
# with a TTL; fail-open. Default OFF — until enabled the voter is purely
# price-derived (no external network call).
EXTERNAL_SENTIMENT_ENABLED=false

# -- Funding carry-cost awareness -----------------------------
# When ON, applies a small bounded confidence haircut (max -0.05) when a trade
# would PAY adverse funding over its expected hold — the carry-cost dimension the
# instantaneous funding signals miss (a swing pays many 8h funding intervals, a
# scalp ~none). Only ever REDUCES confidence; never bypasses risk. Default OFF.
FUNDING_COST_AWARE_ENABLED=false

# -- Learning auto-refit --------------------------------------
# When ON, the learners (confidence calibration, voter weights, per-setup
# expectancy) are re-fitted from closed-trade history every N closed trades so
# they don't go stale. Refitting only updates persisted learner state — it never
# changes a decision unless the learners' own application flags are on. Default
# OFF; safe to leave on alongside any learner you've enabled.
LEARNING_AUTO_REFIT_ENABLED=false
LEARNING_AUTO_REFIT_INTERVAL=25

# -- Live smart-exit auto-close -------------------------------
# When ON, LIVE positions whose thesis has invalidated are auto-closed at market
# (time stop, signal-hold limit, VWAP-reversion done/failed, volume-signal decay)
# instead of riding all the way to the exchange stop-loss. Paper positions
# already auto-close on these triggers; this opt-in extends the SAME checks to
# real positions. Default OFF — live behaviour is unchanged until enabled.
# Requires TIME_STOP_ENABLED=true (the master switch, default true).
# TIME_STOP_LIVE_AUTO_CLOSE=false

# -- LLM Configuration ----------------------------------------
# BYOK (Bring Your Own Key) — supports 10 providers.
# Set LLM_PROVIDER to select. Leave LLM_API_KEY blank for rule-based fallback (FREE).
# Runtime switching available via Telegram: /setllm <provider> <key>
#
# PROVIDER OPTIONS:
#   openai      → GPT-4o, GPT-4-turbo, o1-mini  (best reasoning, paid)
#   anthropic   → Claude Sonnet/Opus             (great safety, paid, pip install anthropic)
#   gemini      → Gemini 2.5 Flash               (free tier, reasoning)  ← DEFAULT
#   groq        → Llama 3.3 70B, Mixtral          (fastest, free tier!)
#   mistral     → Mistral Large                   (cheap, fast, EU)
#   deepseek    → DeepSeek Chat                   (extremely cheap, $0.14/M tokens)
#   together    → 100+ open models                ($5 free credits)
#   ollama      → Local models (Llama3, Mistral)   (free, private, no key needed)
#   openrouter  → Routes to 100+ models            (free models available)
#   alibaba     → Qwen Max/Plus/Turbo             ($30 free credits!)
#   custom      → Any OpenAI-compatible endpoint
#
# Get free keys:
#   Groq:       https://console.groq.com/keys          (no credit card)
#   Gemini:     https://aistudio.google.com/apikey      (no credit card)
#   OpenRouter: https://openrouter.ai/keys              (free models)
#   Ollama:     https://ollama.com/download              (no key needed)
#   Alibaba:    https://dashscope.console.aliyun.com/apiKey  ($30 free credits)
#   OpenAI:     https://platform.openai.com/api-keys
#   Anthropic:  https://console.anthropic.com/
#   DeepSeek:   https://platform.deepseek.com/api_keys
#
# WARNING: Each /analyze call costs ~$0.01-0.03 at GPT-4o pricing.
#          Groq/Gemini/Ollama are FREE alternatives.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SEC=15
LLM_DAILY_LIMIT=500
LLM_DAILY_BUDGET_USD=5.0

# -- Multi-Tier LLM Routing (optional) ----------------------------
# Use DIFFERENT providers for different task types. Each tier falls back
# to LLM_PROVIDER if not set. Keys auto-resolve from provider-specific envs.
#
# TIERS:
#   SCAN     → high-frequency scans (needs speed)         → Gemini Flash (free)
#   THESIS   → trade thesis generation (needs reasoning)  → Claude Sonnet (best quality/cost)
#   LEARNING → reflection / macro learner (needs depth)   → Gemini Flash (free, 1M context)
#   CHAT     → user Q&A via Telegram (balanced)           → Gemini Flash (free, fast)
#
# COST GUIDE (per 1M tokens, input/output):
#   Claude Opus 4.8:   $15 / $75   — overkill for most tasks
#   Claude Sonnet 4.6: $3  / $15   — best reasoning/cost for thesis
#   Gemini 2.5 Flash:  free tier    — ideal for scan/chat/learning
#   Groq Llama 3.3:    free tier    — fastest inference, good fallback
#   DeepSeek Chat:     $0.14 / $0.28 — cheapest paid option
#
LLM_TIER_SCAN_PROVIDER=gemini
LLM_TIER_SCAN_MODEL=gemini-2.5-flash
LLM_TIER_THESIS_PROVIDER=anthropic
LLM_TIER_THESIS_MODEL=claude-sonnet-4-6
LLM_TIER_LEARNING_PROVIDER=gemini
LLM_TIER_LEARNING_MODEL=gemini-2.5-flash
LLM_TIER_CHAT_PROVIDER=gemini
LLM_TIER_CHAT_MODEL=gemini-2.5-flash

# -- Provider-Specific API Keys -----------------------------------
# Set these to enable multi-tier routing with different providers.
# Each provider key is auto-detected by tier routing.
# GEMINI_API_KEY=             # Free at https://aistudio.google.com/apikey
# GROQ_API_KEY=               # Free at https://console.groq.com/keys
# ANTHROPIC_API_KEY=          # https://console.anthropic.com/
# DEEPSEEK_API_KEY=           # https://platform.deepseek.com/api_keys
# OPENAI_API_KEY=             # https://platform.openai.com/api-keys
# ALIBABA_API_KEY=            # Qwen via Bitget Hackathon endpoint (hackathon.bitgetops.com/v1)

# -- On-chain data (BYOK, optional) -------------------------------
# Brings exchange-flow / whale / stablecoin metrics in as a bounded confluence
# vote. INERT without a key (like the LLM rule-based fallback): fail-open, cached,
# never blocks the decision path. Default OFF. Provider-agnostic — point
# ONCHAIN_BASE_URL at a Glassnode/Arkham/Nansen-style endpoint returning
# normalised metrics. See bot/core/onchain.py and docs/ONCHAIN.md.
ONCHAIN_ENABLED=false
ONCHAIN_API_KEY=
ONCHAIN_BASE_URL=
ONCHAIN_PROVIDER=

# -- Commission --------------------------------------------------
# Commission percentage per trade (entry and exit each).
COMMISSION_PCT=0.1

# -- Risk Limits -----------------------------------------------
# The values below mirror the in-code defaults (bot/config.py RiskLimits), so
# copying this file reproduces the bot's actual behavior. Lower them for a more
# conservative posture. NOTE: MAX_POSITION_PCT/MAX_SYMBOL_EXPOSURE_PCT bound
# MARGIN (collateral) as a % of equity — at DEFAULT_LEVERAGE the resulting
# notional exposure is that % × leverage (see bot/risk/risk_engine.py header).
MAX_POSITION_PCT=13.0
MAX_DAILY_LOSS_PCT=5.0
# Absolute-dollar floor on the daily-loss breaker (default 0 = pure %). On a
# tiny live account the % cap is only a few dollars (5% of $128 = $6.40), so a
# couple of normal stop-outs + fees halt the whole day. Set this so the breaker
# needs a MEANINGFUL dollar loss too (e.g. 25) — noise on a micro account no
# longer trips it, while a funded account is unaffected (its % cap dominates).
DAILY_LOSS_BREAKER_MIN_USD=0.0
MAX_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=5
# MAX_CORRELATION: reserved for future pairwise correlation matrix check.
# Currently unused -- concentration is enforced by MAX_CORRELATION_PER_GROUP.
# MAX_CORRELATION=0.85
MIN_RISK_REWARD=1.2
MIN_CONFIDENCE=0.60
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_AFTER_LOSS_SEC=120
MAX_PORTFOLIO_EXPOSURE_PCT=80.0
MAX_SYMBOL_EXPOSURE_PCT=20.0
MAX_CORRELATION_PER_GROUP=2
# Live risk hardening: when ON and running LIVE, applies a stricter portfolio-risk
# posture for real money (forces correlation-aware sizing + covariance VaR on,
# and caps drawdown at LIVE_MAX_DRAWDOWN_PCT) without changing paper/backtest.
# Default OFF; never applies in paper mode.
# LIVE_RISK_HARDENING_ENABLED=false
# LIVE_MAX_DRAWDOWN_PCT=7.0
# Live-performance governor (opt-in, default OFF). A closed-loop backstop that
# scores REALIZED closed-trade outcomes over a rolling window and de-risks when
# the strategy is actually losing: reduces size (×REDUCE_MULT) when the recent
# window underperforms (win rate <= REDUCE_WINRATE OR net-negative), and PAUSES
# trading (rejects) only when it is BOTH losing often (win rate <= PAUSE_WINRATE)
# AND net-negative. Tighten-only; no-op until MIN_SAMPLES closed trades accrue.
# LIVE_PERFORMANCE_GOVERNOR_ENABLED=false
# LIVE_PERF_WINDOW=20
# LIVE_PERF_MIN_SAMPLES=5
# LIVE_PERF_REDUCE_WINRATE=0.40
# LIVE_PERF_PAUSE_WINRATE=0.25
# LIVE_PERF_REDUCE_MULT=0.5
# Portfolio-aware correlation sizing (opt-in, default OFF). When ON, a new trade
# that stacks on already-open positions in the SAME correlation group AND
# direction is sized DOWN (-STEP per such position, floored at FLOOR). Only ever
# reduces size; the notional/margin caps stay authoritative.
# CORRELATION_SIZING_ENABLED=false
# CORRELATION_SIZING_STEP=0.20
# CORRELATION_SIZING_FLOOR=0.5
VOLATILITY_GUARD_ATR_PCT=7.0
STALE_DATA_MAX_AGE_SEC=300
# Macro calendar staleness fail-safe (default ON = safe). When the hardcoded
# macro event schedule runs out (all events in the past), fail closed (BLACKOUT,
# blocks new entries) and alert, instead of silently losing FOMC/CPI protection.
# No effect while future events remain. Set false to accept the gap.
# MACRO_CALENDAR_FAIL_CLOSED_WHEN_STALE=true
REQUIRE_STOP_LOSS=true
# Slippage alert: the proactive monitor warns (live only) when a symbol's mean
# absolute slippage exceeds this %, once it has at least N recorded fills.
# SLIPPAGE_ALERT_MEAN_PCT=0.20
# SLIPPAGE_ALERT_MIN_TRADES=10
# Unprotected-position alert: the proactive monitor fires a CRITICAL alert when
# an open LIVE position has no exchange stop-loss after this many seconds (i.e.
# SL placement / self-heal failed). Must exceed the ~90s placement grace.
# UNPROTECTED_ALERT_GRACE_SECONDS=120

# -- Scanner Settings ------------------------------------------
# How often the engine scans for new signals (seconds).
SCAN_INTERVAL=60

# -- Website Auth & Sync ----------------------------------------
# Session-signing secret. If unset, the website derives a STABLE secret from
# BOT_SYNC_SECRET (sessions survive restarts). Set explicitly for
# multi-replica deployments or to rotate sessions independently.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Shared secret between the bot and the website's /api/bot/sync/* endpoints
# (X-Bot-Secret header). MUST be set to the SAME value in both the bot's env
# and the website deployment's env, or the bot's pushes/pulls are rejected.
BOT_SYNC_SECRET=
# Base URL of the deployed website (no trailing slash). The bot pushes trades/
# signals/equity here and pulls queued credential/control/flatten requests.
# WEBSITE_URL=https://your-deployment.example
# AES-256-GCM key (base64, 32 raw bytes) used to decrypt exchange credentials
# the website encrypted before queuing them for the bot to pull. MUST match the
# website deployment's WEB_CREDS_KEY exactly. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# WEB_CREDS_KEY=
# Shared secret for the bot's WEB USER GATEWAY (/gateway/* on the dashboard
# port :8080) — powers the website's chat drawer and manual-trade placement.
# Fail-closed: the gateway returns 403 for everything until this is set to a
# >=32 char secret, and it MUST be set to the SAME value in the website
# deployment's env. Generate like BOT_SYNC_SECRET:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# WEB_GATEWAY_SECRET=
# Website side only: base URL the Express app uses to reach the bot's gateway
# (default http://localhost:8080; docker: http://runeclaw-bot:8080; remote
# deployments should point at the nginx-TLS /gateway/ proxy).
# BOT_GATEWAY_URL=http://localhost:8080

# -- Transactional email (password reset + email verification) ----
# Provider-agnostic SMTP. Works with ANY provider (Gmail, SendGrid, Postmark,
# Mailgun, Amazon SES, self-hosted Postfix). LEAVE UNSET and the app still runs
# — reset/verify emails become a logged no-op instead of erroring. Set all four
# (HOST, MAIL_FROM, and usually USER/PASS) to actually send.
#   SMTP_SECURE=true  → implicit TLS on port 465. Otherwise STARTTLS on 587.
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=RUNECLAW <no-reply@yourdomain.com>
# Public base URL used to build links in emails (e.g. https://app.yourdomain.com)
# APP_BASE_URL=

# -- Social login / link (all OPTIONAL; each provider hides until configured) ---
# Google & Telegram use client-side widgets:
# GOOGLE_CLIENT_ID=                # OAuth 2.0 Web client ID (Google Cloud console)
# TELEGRAM_BOT_USERNAME=           # bot username WITHOUT @ (for the Login Widget)
#
# Discord & X use redirect OAuth2 — set APP_BASE_URL above and register the
# callback  ${APP_BASE_URL}/api/auth/oauth/<provider>/callback  with the provider.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# X_CLIENT_ID=                     # X/Twitter OAuth2 client (PKCE)
# X_CLIENT_SECRET=
#
# Footer social links — rendered only when set (no guessing at your handles):
# SOCIAL_X_URL=https://x.com/yourhandle
# SOCIAL_DISCORD_URL=https://discord.gg/yourinvite
# SOCIAL_TELEGRAM_URL=https://t.me/HTRUNECLAW_bot

# -- Dashboard API (F-02 FIX) ------------------------------------
# Bearer token required for /api/* endpoints. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=
# Allowed CORS origin (F-03 FIX). Leave empty for same-origin only.
# DASHBOARD_CORS_ORIGIN=https://yourdomain.com

# -- Redis (F-04 FIX) -------------------------------------------
# Password for Redis. Must match docker-compose.yml.
REDIS_PASSWORD=

# -- MCP Server --------------------------------------------------
# Bearer token for MCP tool calls. Generate same as DASHBOARD_TOKEN.
MCP_AUTH_TOKEN=

# -- Liveness monitoring (ops) ------------------------------------
# Dead-man's-switch: set to a monitor URL (e.g. a healthchecks.io check) and
# the engine pings it after each successful tick -- an external alarm fires if
# the process dies or the tick loop stalls. Empty = disabled. Fail-open: ping
# failures never affect trading.
HEALTHCHECK_PING_URL=
HEALTHCHECK_PING_INTERVAL_SEC=60

# -- Continuous Proof-of-PnL publishing ---------------------------
# "Don't trust the dashboard — verify the fills." When ON, the engine re-derives
# the operator's verifiable track record from RAW fills each epoch, seals it
# (SHA-256 publish_hash), and persists it as the latest public-safe publication —
# so the public /proof page and the MCP get_proof_of_pnl tool serve LIVE data
# instead of an empty store. DEFAULT-OFF; fail-open (never affects trading);
# runs only on the LIVE operator path (paper mode has no verifiable fills).
PROOFOFPNL_PUBLISH_ENABLED=0
# How often to publish (seconds, floored at 60). Default hourly.
# PROOFOFPNL_PUBLISH_INTERVAL_S=3600
# How far back to gather fills for each published statement (days).
# PROOFOFPNL_LOOKBACK_DAYS=30
# Optional: attach an ERC-8004 identity card bound to this agent address
# (anchor stays UNVERIFIED until a real tx). Empty = no identity card.
# PROOFOFPNL_AGENT_ADDRESS=
# Account label recorded in the statement (cosmetic). Default "operator".
# PROOFOFPNL_ACCOUNT_ID=operator
# Where the latest sealed publication persists (ensure data/ survives redeploys).
# PROOFOFPNL_PUBLICATION_PATH=data/proofofpnl_publication.json

# -- Public verifiable leaderboard --------------------------------
# Opt the operator IN to the public, anonymous, re-verifiable leaderboard by
# setting a handle (letters/numbers, no email). Each published epoch then also
# registers the sealed statement on the board, ranked by size-agnostic metrics
# (profit factor / round-trips / Sharpe) — never a dollar figure. Empty = the
# operator does NOT appear on the board (default). Requires PROOFOFPNL_PUBLISH_ENABLED.
# PROOFOFPNL_LEADERBOARD_HANDLE=
# Minimum completed round-trips before an entry is ranked (anti-noise). Default 1.
# PROOFOFPNL_LEADERBOARD_MIN_TRIPS=1
# Where the board's handle->publication registry persists.
# PROOFOFPNL_LEADERBOARD_PATH=data/proofofpnl_leaderboard.json

# ── Fable-5 program flags (2026-07-14 session) ──────────────────
# All have safe defaults in bot/config.py — the bot runs fine if these are
# omitted entirely. Listed here so a copied .env is a complete picture.

# Counterfactual shadow book: every gate-rejected idea becomes a priced paper
# trade (recording-only, zero trading impact, zero extra API calls). /shadow
# renders the per-gate scoreboard. Default ON.
SHADOW_BOOK_ENABLED=1

# Continuous equity-curve throttle: scales size off rolling profit factor.
# Default OFF (benchmark A/B was a wash); arm live if the curve degrades.
EQUITY_THROTTLE_ENABLED=0
# EQUITY_THROTTLE_WINDOW=20
# EQUITY_THROTTLE_MIN_SAMPLES=10
# EQUITY_THROTTLE_PF_FULL=1.2
# EQUITY_THROTTLE_PF_FLOOR=0.8
# EQUITY_THROTTLE_FLOOR_MULT=0.25

# Nightly LLM self-audit (advisory only, human merge gate). Reads own evidence,
# proposes allowlisted flag changes, measures each on a frozen benchmark, sends
# the diff to Telegram. Nothing auto-applies. /audit shows the last report.
SELF_AUDIT_ENABLED=1
# SELF_AUDIT_HOUR_UTC=4
# SELF_AUDIT_MAX_PROPOSALS=2
# SELF_AUDIT_DATASET=alts_1h

# Regime-conditional entry timing (csv of regimes where the confirmation gate
# is active). Empty = off unless ENTRY_TIMING_ENABLED. Default empty (A/B
# refuted the chop-only hypothesis).
ENTRY_TIMING_REGIMES=

# Funding-clock gate: blocks entries on the PAYING side of an extreme funding
# rate inside the pre-settlement window (00/08/16 UTC). Narrow, fail-open on
# missing funding data, shadow-book priced. Default ON.
FUNDING_CLOCK_GATE_ENABLED=1
# FUNDING_CLOCK_WINDOW_MIN=30
# FUNDING_CLOCK_EXTREME_RATE=0.0005

# Liquidation-cascade chase veto: blocks entries that chase a range+volume
# explosion (fading stays allowed). Default OFF (A/B: earned on majors, cost on
# alts). Set to 1 to enable globally.
CASCADE_VETO_ENABLED=0
# CASCADE_RANGE_ATR_MULT=2.5
# CASCADE_VOL_MULT=3.0
# CASCADE_RECENT_BARS=3

# Per-class scan toggles. Metals flipped OFF 2026-07-14 on parity evidence
# (14 trades, 14% win, PF 0.10). Set to 1 to re-enable.
SCAN_CLASS_METALS=0
