# ============================================================
# RUNECLAW -- AI Trading Command Core
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All settings have safe defaults. Only TELEGRAM_BOT_TOKEN is
# required for Telegram mode.
# ============================================================

# -- Safety Switches ------------------------------------------
# Simulation mode ON by default. Live trading requires BOTH
# flags to be explicitly set.
SIMULATION_MODE=true
LIVE_TRADING_ENABLED=false

# -- Paper Trading --------------------------------------------
# Starting balance for the paper trading portfolio (USD).
PAPER_BALANCE_USD=10000

# -- Bitget Exchange -------------------------------------------
# API credentials from https://www.bitget.com/account/newapi
# Sandbox mode is always enabled unless overridden in code.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# -- Telegram Bot ----------------------------------------------
# Create a bot via @BotFather on Telegram to get a token.
# CHAT_ID is optional; leave blank to accept commands from any chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- LLM Configuration ----------------------------------------
# OpenAI-compatible API key for AI-powered trade analysis.
# If blank, the analyzer falls back to rule-based strategy.
LLM_API_KEY=
LLM_MODEL=gpt-4o

# -- Risk Limits -----------------------------------------------
# These can be tuned per strategy. Defaults are conservative.
MAX_POSITION_PCT=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=10.0
MAX_OPEN_POSITIONS=5
MAX_CORRELATION=0.85

# -- Scanner Settings ------------------------------------------
# How often the engine scans for new signals (seconds).
SCAN_INTERVAL=60
