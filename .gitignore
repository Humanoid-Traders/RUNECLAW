# --------------------------------------------------------------------------
# RUNECLAW .gitignore
# Python + Node + project-specific exclusions
# --------------------------------------------------------------------------

# -- Python --
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytest_cache/

# -- Node / Next.js --
node_modules/
.next/
out/
.nuxt/
.cache/

# -- Environment & secrets --
.env
.env.*
!.env.example

# -- Logs --
logs/
*.log

# -- IDE --
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -- Docker --
docker-compose.override.yml

# -- Project-specific --
*.db
*.sqlite3
data/
.github/
.github_ci_backup/
.playwright-cli/
