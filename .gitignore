# --------------------------------------------------------------------------
# RUNECLAW .gitignore
# Python + Node + project-specific exclusions
# --------------------------------------------------------------------------

# -- Python --
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytest_cache/

# -- Node / Next.js --
node_modules/
.next/
out/
.nuxt/
.cache/

# -- Environment & secrets --
.env
.env.*
!.env.example

# -- Logs --
logs/*.jsonl
logs/*.jsonl.*
*.log

# Keep only structured trading records
!logs/live_trading_log.csv
!logs/closed_trades.json
!logs/audit_chain.jsonl

# -- Training data & artifacts --
ollama/
v6_data/
AUDIT_REPORT*.md
# Full-universe deep backtest raw results (1.6 MB, regenerable, non-reproducible
# per the wall-clock session finding). The committed summary lives in docs/.
backtest_deep_full_results.json

# -- IDE --
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -- Docker --
docker-compose.override.yml

# -- Project-specific --
*.db
*.sqlite3
data/
# .github/ is intentionally tracked now (CI workflows live here). Only the
# private CI backup dir stays ignored.
.github_ci_backup/
.playwright-cli/
